# =============================================================================
# Dependencies
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =============================================================================
# Build outputs
# =============================================================================
dist/
build/
*.tsbuildinfo

# =============================================================================
# IDE / editor
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db

# =============================================================================
# Test / coverage
# =============================================================================
coverage/
.nyc_output/

# =============================================================================
# Environment / secrets
# =============================================================================
.env
.env.local
.env.*.local
.npmrc

# =============================================================================
# Logs / temp / backup
# =============================================================================
logs/
*.log
tmp/
temp/
*.tmp
*.bak
*.backup
*.backup*

# =============================================================================
# Augment - ignore local state; keep tracked mcp/ docs and coordination.json.
# Use .augment/* (glob) instead of .augment/ (dir) so git descends into the
# directory and the negations below can re-include selected paths.
# =============================================================================
.augment/*
!.augment/mcp/
!.augment/coordination.json
.augment/extensions.json

# =============================================================================
# Beads - ignore local cache, server state, and lock files.
# Keep issues.jsonl, config, hooks, scripts, and READMEs tracked.
# =============================================================================
.beads/cache.db
.beads/beads.db
.beads/beads.db-shm
.beads/beads.db-wal
.beads/.local_version
.beads/metadata.json
.beads/.bd-dolt-ok
.beads/.jsonl.lock
.beads/.beads/
.beads/dolt/
.beads/dolt-server.lock
.beads/dolt-server.pid
.beads/dolt-server.port
.beads/interactions.jsonl
.beads/daemon-error
daemon.log
daemon.lock
beads-bd/
beads_bd/

# =============================================================================
# Benchmarks - local results only; baseline/ and scenarios/ stay tracked
# =============================================================================
.benchmarks/
benchmarks/results.json

# =============================================================================
# CLI - debug and ad-hoc test outputs
# =============================================================================
.cli/
cli/debug-output.txt
cli/test-output.md
cli/test-*.md
cli/wizard-*.md
cli/evaluation/

# =============================================================================
# Root-level test/work artifacts
# =============================================================================
completed.jsonl
test-results.jsonl
docs/beads-tasks.jsonl

# =============================================================================
# Task execution summaries (transient working files)
# =============================================================================
*-EXECUTION-SUMMARY.md
*-TASKS-SUMMARY.md
*SUMMARY.md
IMPLEMENTATION_SUMMARY.md
TASK_COMPLETION_SUMMARY.md

# =============================================================================
# Internal / development-only documentation (not for end users)
# =============================================================================
project-status.md
publishing.md
npm-publish-checklist.md
test-modules.md
analyze-inspect-tasks.md

# =============================================================================
# Work-in-progress source trees (root-level only; do not match cli/src/ etc.)
# =============================================================================
/src/
/dev/
.codegraph/

# =============================================================================
# User-generated content - DO NOT IGNORE
# screenplays/ is created by writing-standards/screenplay; preserve versioning.
# =============================================================================